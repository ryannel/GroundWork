// OutboxRepository implements service.OutboxRepository.
type OutboxRepository struct {
	db *DB
}

var _ service.OutboxRepository = (*OutboxRepository)(nil)

// NewOutboxRepository creates a new outbox repository.
func NewOutboxRepository(db *DB) *OutboxRepository {
	return &OutboxRepository{db: db}
}

// InsertEvent saves a domain event to the outbox table within the caller's
// transaction, so the event is committed atomically with the domain mutation.
func (r *OutboxRepository) InsertEvent(ctx context.Context, tx service.Transaction, eventType string, payload []byte) error {
	pgTx, ok := tx.(*Transaction)
	if !ok || pgTx.tx == nil {
		return fmt.Errorf("outbox InsertEvent requires a postgres transaction, got %T", tx)
	}
	const q = `INSERT INTO outbox_events (event_type, payload) VALUES ($1, $2::jsonb)`
	if _, err := pgTx.tx.ExecContext(ctx, q, eventType, string(payload)); err != nil {
		return fmt.Errorf("insert outbox event: %w", err)
	}
	return nil
}

// PollUnpublished fetches unpublished events from the outbox, oldest first.
func (r *OutboxRepository) PollUnpublished(ctx context.Context, limit int) ([]service.OutboxEvent, error) {
	const q = `SELECT id, event_type, payload, EXTRACT(EPOCH FROM created_at)::bigint
		FROM outbox_events
		WHERE published_at IS NULL
		ORDER BY created_at
		LIMIT $1`
	rows, err := r.db.DB.QueryContext(ctx, q, limit)
	if err != nil {
		return nil, fmt.Errorf("poll outbox: %w", err)
	}
	defer rows.Close()

	var events []service.OutboxEvent
	for rows.Next() {
		var e service.OutboxEvent
		if err := rows.Scan(&e.ID, &e.EventType, &e.Payload, &e.CreatedAt); err != nil {
			return nil, fmt.Errorf("scan outbox event: %w", err)
		}
		events = append(events, e)
	}
	return events, rows.Err()
}

// MarkPublished marks an outbox event as successfully published.
func (r *OutboxRepository) MarkPublished(ctx context.Context, id string) error {
	if _, err := r.db.DB.ExecContext(ctx,
		`UPDATE outbox_events SET published_at = NOW() WHERE id = $1`, id); err != nil {
		return fmt.Errorf("mark outbox event %s published: %w", id, err)
	}
	return nil
}
