<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <!-- A strict CSP is achievable because all privileged data flows over IPC,
         not fetch. style-src 'unsafe-inline' carries Vite's dev-mode style
         injection; scripts stay 'self'-only in every mode
         (docs/principles/stack/electron/security.md). -->
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= name %></title>
  </head>
  <body>
    <div id="root"></div>
    <script type="module" src="/src/main.tsx"></script>
  </body>
</html>
