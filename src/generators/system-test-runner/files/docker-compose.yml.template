# Root docker-compose for the platform.
#
# Infrastructure services always start.
# Application services are opt-in via profiles (e.g. `core`, `ml`).
#
# Usage:
#   docker-compose up -d            — infra only
#   docker-compose --profile all up -d — everything

services:

  # ── Infrastructure ────────────────────────────────────────────────────────

  db:
    image: pgvector/pgvector:pg15
    container_name: <%= projectPrefix %>-db
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${DB_USER:-postgres}
      POSTGRES_PASSWORD: ${DB_PASSWORD:-postgres}
      POSTGRES_DB: ${DB_NAME:-<%= projectPrefix %>}
    ports:
      - "127.0.0.1:${DB_PORT:-5432}:5432"
    volumes:
      - db_data:/var/lib/postgresql/data
    networks:
      - <%= projectPrefix %>-net
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER:-postgres}"]
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: valkey/valkey:8
    container_name: <%= projectPrefix %>-redis
    restart: unless-stopped
    ports:
      - "127.0.0.1:${REDIS_PORT:-6379}:6379"
    networks:
      - <%= projectPrefix %>-net
    healthcheck:
      test: ["CMD", "valkey-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  pubsub:
    image: gcr.io/google.com/cloudsdktool/cloud-sdk:emulators
    platform: linux/amd64
    container_name: <%= projectPrefix %>-pubsub
    restart: unless-stopped
    command: gcloud beta emulators pubsub start --host-port=0.0.0.0:${PUBSUB_PORT:-8085} --project=${GCP_PROJECT_ID:-<%= projectPrefix %>-local}
    ports:
      - "127.0.0.1:${PUBSUB_PORT:-8085}:${PUBSUB_PORT:-8085}"
    networks:
      - <%= projectPrefix %>-net

  # ── Observability ─────────────────────────────────────────────────────────

  aspire-dashboard:
    image: mcr.microsoft.com/dotnet/aspire-dashboard:latest
    container_name: <%= projectPrefix %>-aspire
    restart: unless-stopped
    ports:
      - "18888:18888"   # Dashboard UI
      - "18889:18889"   # OTLP gRPC
    environment:
      - DOTNET_DASHBOARD_UNSECURED_ALLOW_ANONYMOUS=true
    networks:
      - <%= projectPrefix %>-net

  otel-collector:
    image: otel/opentelemetry-collector-contrib:latest
    container_name: <%= projectPrefix %>-otel-collector
    restart: unless-stopped
    # command: ["--config", "/etc/otel/config.yaml"]
    ports:
      - "4317:4317"   # OTLP gRPC (services running outside Docker send here)
      - "4318:4318"   # OTLP HTTP
    depends_on:
      - aspire-dashboard
    networks:
      - <%= projectPrefix %>-net

networks:
  <%= projectPrefix %>-net:
    driver: bridge

volumes:
  db_data:
