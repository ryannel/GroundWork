#!/usr/bin/env bash

# ==========================================
# DOMAIN: QUALITY
# Commands: test, lint
# ==========================================

function cmd_test() {
  local MODE="$1"
  local KEEP=false
  local INTEGRATION=false
  for arg in "$@"; do
    if [ "$arg" == "--keep" ]; then KEEP=true; fi
    if [ "$arg" == "--integration" ]; then INTEGRATION=true; fi
  done

  if [ ! -d "$ROOT_DIR/tests/system" ]; then
    print_logo "Running Tests"
    print_info "No system tests found."
    return 0
  fi

  if [ "$MODE" == "integration" ]; then
    print_logo "Running Integration Tests"
    # Full loop: boot the dev stack, migrate, run the suite with FAIL-LOUD
    # flags, then tear down (unless --keep).
    cmd_start
    cmd_migrate
    print_step "Running System Tests (Pytest, REQUIRE_* enabled)"
    local rc=0
    ( cd "$ROOT_DIR/tests" && \
      GROUNDWORK_REQUIRE_SERVICES=1 GROUNDWORK_REQUIRE_TRACES=1 uv run pytest system/ ) || rc=$?
    if ! $KEEP; then
      cmd_stop
    fi
    if [ "$rc" -ne 0 ]; then
      fail "Integration tests failed" "Re-run with './dev test integration --keep' to inspect the running stack"
    fi
    echo ""
    print_success "Integration tests passed."
    return 0
  fi

  if [ "$MODE" == "bet" ]; then
    local SLUG="$2"
    if [ -z "$SLUG" ]; then
      fail "Usage: ./dev test bet <slug>" "Provide the bet slug (e.g. ./dev test bet user-auth)"
    fi

    local BET_DIR="$ROOT_DIR/tests/bets/$SLUG"
    if [ ! -d "$BET_DIR" ]; then
      fail "Bet test directory not found: tests/bets/$SLUG" \
           "Run './dev new bet $SLUG' and author the test stubs first."
    fi

    if $INTEGRATION; then
      print_logo "Running Bet Integration Tests — $SLUG"
      cmd_start
      cmd_migrate
      # Install playwright browser binaries if any bet test uses playwright.
      if grep -r "playwright\|from playwright" "$BET_DIR/" 2>/dev/null | grep -q .; then
        print_step "Installing Playwright browser binaries (chromium)"
        ( cd "$ROOT_DIR/tests" && uv run playwright install chromium ) || true
      fi
      print_step "Running bet-progress suite: bets/$SLUG/ (REQUIRE_SERVICES enabled)"
      local rc=0
      ( cd "$ROOT_DIR/tests" && \
        GROUNDWORK_REQUIRE_SERVICES=1 uv run pytest "bets/$SLUG/" ) || rc=$?
      if ! $KEEP; then
        cmd_stop
      fi
      if [ "$rc" -ne 0 ]; then
        fail "Bet tests failed" "Re-run with '--keep' to inspect the running stack"
      fi
      echo ""
      print_success "Bet integration tests passed: $SLUG"
    else
      # Fast inner loop against an already-running stack.
      print_logo "Running Bet Tests — $SLUG"
      print_step "Running bet-progress suite: bets/$SLUG/"
      cd "$ROOT_DIR/tests" && uv run pytest "bets/$SLUG/"
      echo ""
      print_success "Bet tests complete: $SLUG"
    fi
    return 0
  fi

  # Default: fast inner loop against an already-running stack.
  print_logo "Running Tests"
  print_step "Running System Tests (Pytest)"
  cd "$ROOT_DIR/tests" && uv run pytest system/
  echo ""
  print_success "Testing complete."
}

function cmd_lint() {
  print_logo "Running Linters"

  for svc in $(ls "$ROOT_DIR/services" 2>/dev/null || true); do
    local svc_dir="$ROOT_DIR/services/$svc"
    
    if [ -f "$svc_dir/.golangci.yml" ]; then
      print_step "Linting Go Service: $svc"
      (cd "$svc_dir" && golangci-lint run)
    fi
  done

  echo ""
  print_success "Linting complete."
}
