#!/usr/bin/env bash

# Resolve absolute path to project root
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export ROOT_DIR

# Source UI helper
source "${ROOT_DIR}/scripts/cli/_ui.sh"

# ==========================================
# GRACEFUL INTERRUPTION (Ctrl+C)
# ==========================================
function cleanup_on_interrupt() {
  echo ""
  stop_spinner "Aborted by user" ""
  print_error_card "Process Interrupted" "Any partially started services may need to be stopped via './dev stop'"
  exit 130
}
trap cleanup_on_interrupt SIGINT

# ==========================================
# HELP DASHBOARD
# ==========================================
function show_help() {
  print_logo
  echo -e "  Local Development CLI for ${CLI_APP_NAME}"
  echo ""
  echo -e "  ${BOLD}USAGE${NC}"
  echo -e "  ${DIM}$ ${MAGENTA}./dev${NC} ${CYAN}<verb>${NC} [nouns...]"
  
  print_category "LIFECYCLE"
  print_cmd "start" "Spin up environment (--docker)"
  print_cmd "migrate" "Create service DBs & apply schemas"
  print_cmd "stop" "Tear down components"
  print_cmd "logs" "Tail output logs"
  print_cmd "status" "Print local endpoints (--json)"
  print_cmd "clean" "Deep teardown & wipe (--hard)"

  print_category "MAINTENANCE & QUALITY"
  print_cmd "doctor" "Verify environment"
  print_cmd "test" "Execute testing suites"
  print_cmd "lint" "Run static analysis"
  echo ""
}

while [[ "$1" == -* ]]; do
  case "$1" in
    -v|--verbose)
      export VERBOSE=1
      shift
      ;;
    -h|--help)
      show_help
      exit 0
      ;;
    *)
      break
      ;;
  esac
done

COMMAND=$1
shift || true
TARGETS=("$@")

if [[ -z "$COMMAND" || "$COMMAND" == "help" ]]; then
  show_help
  exit 0
fi

# Sourcing the Domain Execution Modules
source "${ROOT_DIR}/scripts/cli/lifecycle.sh"
source "${ROOT_DIR}/scripts/cli/quality.sh"
source "${ROOT_DIR}/scripts/cli/doctor.sh"

# Route commands securely
if declare -f "cmd_${COMMAND}" > /dev/null; then
  "cmd_${COMMAND}" "${TARGETS[@]}"
else
  print_error "Unknown command: ${COMMAND}"
  show_help
  exit 1
fi
