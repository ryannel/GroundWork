from src.core.domain.entities import ExampleEntity, PaginatedResult
from src.core.domain.exceptions import NotFoundError
<% if (postgres) { %>
from src.core.domain.protocols import ExampleRepository
<% } %>
<% if (messaging !== 'none') { %>
from src.core.domain.protocols import MessageQueue
<% } %>
<% if (llm) { %>
from src.core.domain.llm_port import LLMGateway
<% } %>
import uuid

class ExampleService:
    def __init__(
        self,
<% if (postgres) { %>
        repository: ExampleRepository,
<% } %>
<% if (messaging !== 'none') { %>
        message_queue: MessageQueue,
<% } %>
<% if (llm) { %>
        llm_gateway: LLMGateway,
<% } %>
    ):
<% if (postgres) { %>
        self.repository = repository
<% } %>
<% if (messaging !== 'none') { %>
        self.message_queue = message_queue
<% } %>
<% if (llm) { %>
        self.llm_gateway = llm_gateway
<% } %>
<% if (!postgres && messaging === 'none' && !llm) { %>
        pass
<% } %>

    async def create_example(self, name: str) -> ExampleEntity:
        entity = ExampleEntity(id=str(uuid.uuid4()), name=name)
        
<% if (llm) { %>
        # Generate description using LLM
        description = await self.llm_gateway.generate_text(f"Describe a thing named {name}")
        entity.description = description
<% } %>

<% if (postgres) { %>
        await self.repository.save(entity)
<% } %>

<% if (messaging !== 'none') { %>
        await self.message_queue.publish("example.created", entity.model_dump())
<% } %>

        return entity

<% if (postgres) { %>
    async def get_example(self, entity_id: str) -> ExampleEntity:
        entity = await self.repository.get_by_id(entity_id)
        if not entity:
            raise NotFoundError(f"Example {entity_id} not found")
        return entity
        
    async def list_examples(self, limit: int = 10, cursor: str | None = None) -> PaginatedResult[ExampleEntity]:
        return await self.repository.list_items(limit, cursor)
<% } %>
