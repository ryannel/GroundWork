// Bet: the raw gateway has no implementation yet. While the stub returns an
// error this test Skips, so a freshly scaffolded service stays green. The moment
// you implement GenerateText it runs for real and asserts the contract — your
// cue that the bet is delivered and this Skip can come out. The port is the
// spec, the adapter is the bet.
func TestRawGatewayGeneratesText(t *testing.T) {
	out, err := NewLLMGatewayAdapter().GenerateText(context.Background(), "ping", 8)
	if err != nil {
		t.Skipf("bet: LLM raw gateway not implemented yet: %v", err)
	}
	if out == "" {
		t.Fatal("expected non-empty text from the LLM gateway")
	}
}
