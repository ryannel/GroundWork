// enforced at compile time, the strongest place to put it.
var _ gateway.LLMGateway = (*LLMGatewayAdapter)(nil)

func TestLLMGatewayConformsToPort(t *testing.T) {
	var _ gateway.LLMGateway = (*LLMGatewayAdapter)(nil)
}
