# The tree-sitter grammar devDependencies carry mutually incompatible
# peerOptional ranges on the native `tree-sitter` package (e.g.
# tree-sitter-c-sharp wants ^0.25, the kotlin/lua grammars want ^0.22).
# They are dev-only (repo-map parsing/tests) and never ship in the npm
# tarball, so the conflict is cosmetic — but strict `npm ci` in CI rejects
# it. legacy-peer-deps makes CI install the same resolution that local
# installs already use.
legacy-peer-deps=true
