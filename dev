#!/usr/bin/env bash
set -e

# Change to the directory of this script to ensure relative paths work
cd "$(dirname "$0")"

# Load environment variables if present
if [ -f ".env" ]; then
  set -a
  source .env
  set +a
fi

# Source UI functions
if [ -f "scripts/_ui.sh" ]; then
  source scripts/_ui.sh
else
  # Fallback functions if ui script is missing
  print_logo() { echo "GroundWork Dev CLI"; }
  print_step() { echo "-> $1"; }
  print_info() { echo "  $1"; }
  print_error() { echo "ERROR: $1"; }
  fail() { echo "ERROR: $1"; exit 1; }
fi

# ── Shared harness setup ──────────────────────────────────────────────────────
# One source of truth for the test toolchain so `./dev test ...`, `./dev ci`, and
# the GitHub workflows all build and install identically — run it locally and you
# have run the build.

TEST_VENV="tests/scaffolds/venv"

# uv creates the venv and installs the pinned tests/requirements.txt. uv is already
# required for the Python scaffolds, so the harness has no separate pip dependency.
ensure_test_env() {
  if [ ! -x "$TEST_VENV/bin/pytest" ]; then
    command -v uv >/dev/null 2>&1 || fail "uv is required (https://docs.astral.sh/uv/); brew install uv"
    print_substep "Creating test venv (uv, pinned tests/requirements.txt)..."
    uv venv "$TEST_VENV" >/dev/null
    uv pip install --python "$TEST_VENV/bin/python" -r tests/requirements.txt >/dev/null
  fi
  # shellcheck disable=SC1091
  source "$TEST_VENV/bin/activate"
}

# Install node deps from the lockfile (npm ci, matching CI) only when missing, then
# build the generators + dev-cli bundle. In CI `npm ci` has already run, so this just
# builds; locally it installs once then reuses node_modules.
ensure_build() {
  [ -d node_modules ] || { print_substep "Installing node deps (npm ci)..."; npm ci; }
  npm run build
}

COMMAND=$1

case "$COMMAND" in
  sim)
    # The simulation lifecycle — flow testing driven end to end from one place
    # (or from a chat session). Each verb is a standalone script under
    # scripts/sim/; ./dev only routes. See the contributor skill's
    # references/testing.md for the driver loop.
    SUBCMD=$2
    case "$SUBCMD" in
      run|follow|status|list|stop|judge|assess|suites|checkpoint)
        exec bash "scripts/sim/$SUBCMD.sh" "${@:3}"
        ;;
      *)
        print_logo "Simulation"
        echo -e "  Flow-testing lifecycle: trigger → follow → assess → grade"
        echo ""
        echo -e "  ${BOLD}USAGE${NC}"
        echo -e "  ${DIM}$ ${MAGENTA}./dev${NC} ${CYAN}sim${NC} <verb> [name] [flags]"
        print_category "THE DRIVER LOOP"
        print_cmd "run" "Provision + seed + launch a sim in a background session (--path, --suite, --model, --until, --attended, --reuse)"
        print_cmd "follow" "Block until the session finishes; print a digest (--timeout, --stall)"
        print_cmd "assess" "Produce the full review bundle: transcript + checklist + judge verdict + findings scaffold"
        print_category "AROUND IT"
        print_cmd "status" "Recorded runs + live sessions for a sandbox (--json)"
        print_cmd "list" "Latest recorded run per sandbox"
        print_cmd "stop" "Stop the latest recorded session (--judge for the judge's)"
        print_cmd "judge" "Launch a fresh-context /judge session by itself (--model)"
        print_cmd "suites" "List scenario suites with persona + last-run info"
        print_cmd "checkpoint" "capture <name> --as <label> | list — with staleness flags"
        echo ""
        ;;
    esac
    ;;
  ci)
    # Single entry point that reproduces the GitHub PR build (the fast, blocking
    # gates) end to end. `./dev ci` locally == the required CI jobs. The heavy
    # real-stack boot lives in `./dev test scaffolds` / the integration workflow.
    print_logo "CI"
    print_step "Reproducing the required CI gates locally..."
    ensure_build
    ensure_test_env
    print_step "[1/5] Skill conformance lint + sim invariants..."
    python3 scripts/lint_skills.py
    bash scripts/check_sim_invariants.sh
    print_step "[2/5] Generation tests (structural, all combos)..."
    pytest tests/scaffolds/test_generation*.py -q
    print_step "[3/5] Contract tests (bundle freshness, adopt-merge, migration coverage)..."
    pytest tests/scaffolds/test_contracts.py tests/scaffolds/test_brownfield_adopt.py tests/scaffolds/test_skill_sync.py tests/cli/test_migration_gate.py -q
    print_step "[4/5] CLI contract tests..."
    pytest tests/cli/ -q
    print_step "[5/5] Compilation tests (pairwise compile checks; needs go + uv + pnpm)..."
    pytest tests/scaffolds/test_compilation.py -q
    print_success "All required CI gates passed. (Run the full real-stack boot with: ./dev test scaffolds)"
    ;;
  test|eval)
    SUBCMD=$2
    if [ "$SUBCMD" = "nx" ]; then
      print_logo "Testing"
      print_step "Running Nx tests..."
      npx nx run-many -t test
    elif [ "$SUBCMD" = "generation" ]; then
      print_logo "Testing"
      ensure_build
      ensure_test_env
      print_step "Running Generation Tests (structural, all combos)..."
      pytest tests/scaffolds/test_generation*.py -v -s
    elif [ "$SUBCMD" = "cli" ]; then
      print_logo "Testing"
      ensure_test_env
      print_step "Running CLI contract tests (init/update/check, manifest, migrations, upgrade path)..."
      pytest tests/cli/ -v
    elif [ "$SUBCMD" = "compilation" ]; then
      print_logo "Testing"
      ensure_build
      ensure_test_env
      print_step "Running Compilation Tests (pairwise, compile checks)..."
      pytest tests/scaffolds/test_compilation.py -v -s
    elif [ "$SUBCMD" = "scaffolds" ]; then
      print_logo "Testing"
      ensure_build
      ensure_test_env
      print_step "Running Scaffold End-to-End Tests..."
      pytest tests/scaffolds/test_scaffolds.py -v -s
    elif [ "$SUBCMD" = "contracts" ]; then
      print_logo "Testing"
      ensure_build
      ensure_test_env
      print_step "Running Contract Tests (fast: bundle freshness, adopt-merge idempotency, migration coverage)..."
      pytest tests/scaffolds/test_contracts.py tests/scaffolds/test_brownfield_adopt.py tests/scaffolds/test_skill_sync.py tests/cli/test_migration_gate.py -v -s
    elif [ "$SUBCMD" = "clean" ]; then
      print_logo "Cleaning"
      print_step "Cleaning legacy eval sandboxes and the brownfield repo cache..."
      rm -rf .sandboxes/evals tests/evals/cache/* .sandboxes/.cache
      print_success "Cleaned."
    elif [ "$SUBCMD" = "validate" ]; then
      # Scaffold boot-prober (validate_scaffold.py) — stdlib only, no venv needed.
      SUITE=$3
      print_logo "Scaffold Validation"
      EXTRA_ARGS="${@:4}"
      if [ -n "$SUITE" ]; then
          python3 tests/evals/validate_scaffold.py --suite "$SUITE" $EXTRA_ARGS
      else
          python3 tests/evals/validate_scaffold.py $EXTRA_ARGS
      fi
    else
      print_logo
      echo -e "  Local Development CLI for GroundWork"
      echo ""
      echo -e "  ${BOLD}USAGE${NC}"
      echo -e "  ${DIM}$ ${MAGENTA}./dev${NC} ${CYAN}test${NC} [action]"
      echo ""
      print_info "Flow testing is now simulation-based — see ./dev sandbox --simulate."

      print_category "ACTIONS"
      print_cmd "validate" "Manually probe a scaffold workspace (boots + health checks)"
      print_cmd "clean" "Clear legacy eval caches & sandboxes"
      echo ""
    fi
    ;;
  sandbox)
    # `./dev sandbox review [name] [--session <id>]` — render the latest chat
    # transcript for a sandbox into a readable Markdown bundle for assessment.
    if [ "$2" = "review" ]; then
      RNAME="greenfield"
      RSESSION=""
      shift 2
      while [ $# -gt 0 ]; do
        case "$1" in
          --session) RSESSION="$2"; shift 2 ;;
          --session=*) RSESSION="${1#*=}"; shift ;;
          -*) print_error "Unknown flag: $1"; exit 1 ;;
          *) RNAME="$1"; shift ;;
        esac
      done
      SANDBOX_DIR="$PWD/.sandboxes/$RNAME"
      OUT_DIR="$PWD/.sandboxes/$RNAME-review"
      if [ ! -d "$SANDBOX_DIR" ]; then
        fail "No sandbox at .sandboxes/$RNAME. Create one with: ./dev sandbox $RNAME --simulate"
      fi
      print_logo "Sandbox Review"
      print_step "Rendering transcript for .sandboxes/$RNAME → .sandboxes/$RNAME-review"
      python3 "$PWD/scripts/render_transcript.py" "$SANDBOX_DIR" "$OUT_DIR" $RSESSION
      print_step "Running structural checklist (durable artifacts)..."
      python3 "$PWD/scripts/sandbox_checklist.py" "$SANDBOX_DIR" "$OUT_DIR/checklist.md"
      print_success "Review bundle ready at .sandboxes/$RNAME-review/"
      print_info "Open .sandboxes/$RNAME-review/conversation.md and checklist.md alongside .sandboxes/$RNAME/docs/."
      print_info "For an independent quality verdict, open a NEW chat in .sandboxes/$RNAME and run /judge."
      exit 0
    fi

    # Relocated verbs — the sim lifecycle lives under `./dev sim` now. Old
    # spellings keep working for one cycle, with a pointer.
    if [ "$2" = "status" ] || [ "$2" = "judge" ]; then
      print_info "(moved: use ./dev sim $2 — forwarding)"
      exec bash "scripts/sim/$2.sh" "${@:3}"
    fi
    if [ "$2" = "checkpoint" ]; then
      print_info "(moved: use ./dev sim checkpoint — forwarding)"
      exec bash "scripts/sim/checkpoint.sh" "${@:3}"
    fi

    # Create a standalone GroundWork project sandbox seeded with the same
    # starting state a real user gets from `npx groundwork init`. Unlike the
    # eval sandbox (.sandboxes/evals), this one is NOT wiped by eval runs, so
    # you can start a fresh chat from the folder and walk the greenfield flow.
    NAME=""
    FORCE=0
    NOBUILD=0
    SIMULATE=0
    RUN=0
    RUN_MODEL="sonnet"
    UNTIL=""
    FLOW_PATH="greenfield"
    SUITE=""
    FROM=""
    REPO=""
    REFRESH=0
    for arg in "${@:2}"; do
      case "$arg" in
        --force) FORCE=1 ;;
        --no-build) NOBUILD=1 ;;
        --brownfield) FLOW_PATH="brownfield" ;;
        # Seed a sealed bet ready for the Delivery phase (implies --simulate).
        --delivery) FLOW_PATH="delivery"; SIMULATE=1 ;;
        --simulate) SIMULATE=1 ;;
        --simulate=*) SIMULATE=1; SUITE="${arg#*=}" ;;
        # Deprecated spelling — `./dev sim run` owns launch now. Collected here
        # so the whole invocation can be forwarded after parsing.
        --run) RUN=1; SIMULATE=1 ;;
        --model=*) RUN_MODEL="${arg#*=}" ;;
        --until=*) UNTIL="${arg#*=}" ;;
        --from) print_error "Use --from=<label> (no space)."; exit 1 ;;
        --from=*) FROM="${arg#*=}" ;;
        # Seed the brownfield baseline from a real GitHub repo (any repo). It is
        # cloned once into a gitignored cache under .sandboxes/ and reused across
        # runs. Format: owner/repo or owner/repo@ref. Implies --brownfield.
        --repo=*) REPO="${arg#*=}"; FLOW_PATH="brownfield" ;;
        --refresh) REFRESH=1 ;;
        -*) print_error "Unknown flag: $arg"; exit 1 ;;
        *) NAME="$arg" ;;
      esac
    done
    # Deprecated `--run` spelling: forward the whole invocation to `sim run`,
    # which provisions (by calling back into this verb without --run) and launches.
    if [ "$RUN" -eq 1 ]; then
      print_info "(moved: use ./dev sim run — forwarding)"
      FWD=()
      [ -n "$NAME" ] && FWD+=("$NAME")
      FWD+=("--path=$FLOW_PATH")
      [ -n "$SUITE" ] && FWD+=("--suite=$SUITE")
      [ -n "$REPO" ] && FWD+=("--repo=$REPO")
      [ -n "$FROM" ] && FWD+=("--from=$FROM")
      [ -n "$UNTIL" ] && FWD+=("--until=$UNTIL")
      [ "$NOBUILD" -eq 1 ] && FWD+=(--no-build)
      FWD+=("--model=$RUN_MODEL")
      exec bash scripts/sim/run.sh "${FWD[@]}"
    fi

    # Default the sandbox dir name and suite to the flow path when unset.
    [ -n "$NAME" ] || NAME="$FLOW_PATH"
    if [ -z "$SUITE" ]; then
      case "$FLOW_PATH" in
        brownfield) SUITE="brownfield_monorepo" ;;
        delivery)   SUITE="delivery_task_capture" ;;
        *)          SUITE="storytelling_engine" ;;
      esac
    fi

    REPO_ROOT="$PWD"
    SANDBOX_DIR="$REPO_ROOT/.sandboxes/$NAME"
    BROWNFIELD_FIXTURE="$REPO_ROOT/tests/evals/fixtures/brownfield_monorepo/00_codebase"
    DELIVERY_FIXTURE="$REPO_ROOT/tests/evals/scenarios/delivery_task_capture/fixture"

    print_logo "Sandbox"
    print_step "Target: .sandboxes/$NAME"

    if [ -e "$SANDBOX_DIR" ] && [ -n "$(ls -A "$SANDBOX_DIR" 2>/dev/null)" ]; then
      if [ "$FORCE" -ne 1 ]; then
        printf "  %s already exists and is not empty. Overwrite? [y/N] " "$SANDBOX_DIR"
        read -r REPLY
        case "$REPLY" in
          [yY]|[yY][eE][sS]) ;;
          *) print_error "Aborted."; exit 1 ;;
        esac
      fi
      print_substep "Wiping existing sandbox..."
      rm -rf "$SANDBOX_DIR"
    fi
    mkdir -p "$SANDBOX_DIR"

    if [ "$NOBUILD" -ne 1 ]; then
      print_step "Building generators (dist/)..."
      npm install --silent && npm run build
    else
      print_substep "Skipping build (--no-build)."
    fi

    # --- Brownfield: lay down the existing codebase and commit it as the baseline ---
    # Brownfield adoption diffs against a real starting commit (infra-adopt records
    # baseline.source_commit), so the existing code must be committed BEFORE GroundWork
    # touches anything. A brownfield repo is deliberately NOT an Nx workspace — the
    # infra-adopt phase bootstraps nx.json itself.
    if [ "$FLOW_PATH" = "brownfield" ]; then
      if [ -n "$REPO" ]; then
        # Seed from a real GitHub repo. Clone ONCE into a gitignored cache under
        # .sandboxes/ (recursing submodules) and reuse it across runs so a 200MB+
        # monorepo isn't re-fetched every time. Then rsync into the sandbox with
        # all VCS metadata stripped (including nested submodule .git) so the
        # baseline is one clean commit GroundWork adopts.
        command -v gh >/dev/null 2>&1 || fail "gh CLI required for --repo (brew install gh; gh auth login)."
        REPO_REF=""; REPO_SLUG_SRC="$REPO"
        case "$REPO" in *@*) REPO_REF="${REPO#*@}"; REPO_SLUG_SRC="${REPO%@*}" ;; esac
        CACHE_SLUG="$(printf '%s' "$REPO_SLUG_SRC" | tr '/' '__')"
        CACHE_DIR="$REPO_ROOT/.sandboxes/.cache/repos/$CACHE_SLUG"
        if [ "$REFRESH" -eq 1 ] && [ -d "$CACHE_DIR" ]; then
          print_substep "Refreshing repo cache ($REPO_SLUG_SRC)..."
          rm -rf "$CACHE_DIR"
        fi
        if [ ! -d "$CACHE_DIR" ]; then
          print_step "Cloning $REPO_SLUG_SRC into repo cache (once; recursing submodules)..."
          mkdir -p "$(dirname "$CACHE_DIR")"
          gh repo clone "$REPO_SLUG_SRC" "$CACHE_DIR" -- \
            --depth 1 --recurse-submodules --shallow-submodules \
            || fail "Clone failed for $REPO_SLUG_SRC (check access / gh auth)."
          if [ -n "$REPO_REF" ]; then
            print_substep "Checking out ref $REPO_REF..."
            git -C "$CACHE_DIR" fetch -q --depth 1 origin "$REPO_REF" \
              && git -C "$CACHE_DIR" checkout -q FETCH_HEAD \
              && git -C "$CACHE_DIR" submodule update --init --recursive --depth 1 \
              || fail "Could not check out ref '$REPO_REF'."
          fi
        else
          print_step "Reusing cached clone of $REPO_SLUG_SRC (--refresh to re-pull)..."
        fi
        print_substep "Seeding sandbox baseline from cache (stripping VCS metadata)..."
        rsync -a --exclude='.git' "$CACHE_DIR"/ "$SANDBOX_DIR"/
      else
        # A suite that ships its own fixture (tests/evals/scenarios/<suite>/fixture)
        # seeds from it; everything else shares the synthetic monorepo fixture.
        SUITE_FIXTURE="$REPO_ROOT/tests/evals/scenarios/$SUITE/fixture"
        if [ -d "$SUITE_FIXTURE" ]; then
          print_step "Seeding existing codebase from the $SUITE suite fixture (brownfield baseline)..."
          cp -R "$SUITE_FIXTURE/." "$SANDBOX_DIR/"
        else
          [ -d "$BROWNFIELD_FIXTURE" ] || fail "Brownfield fixture missing: $BROWNFIELD_FIXTURE"
          print_step "Seeding existing codebase from synthetic fixture (brownfield baseline)..."
          cp -R "$BROWNFIELD_FIXTURE/." "$SANDBOX_DIR/"
        fi
      fi
    elif [ "$FLOW_PATH" = "delivery" ]; then
      # Delivery: lay down a project mid-flow — a sealed, approved bet ready for the
      # Delivery phase. The fixture carries the pitch, technical design, decomposition
      # tree, and unimplemented `taskcli` stubs; the approval tag is created after init
      # so readiness's sealed-baseline gate is satisfiable.
      [ -d "$DELIVERY_FIXTURE" ] || fail "Delivery fixture missing: $DELIVERY_FIXTURE"
      print_step "Seeding sealed 'task-capture' bet from the delivery fixture..."
      cp -R "$DELIVERY_FIXTURE/." "$SANDBOX_DIR/"
    else
      # Greenfield: a realistic Nx-style project root so the scaffold skill is happy.
      printf '{"name": "%s"}\n' "$NAME" > "$SANDBOX_DIR/package.json"
      printf '{}\n' > "$SANDBOX_DIR/nx.json"
    fi

    # This sandbox is nested inside the GroundWork repo. Without a local boundary,
    # a chat opened here could inherit the repo's CLAUDE.md / contributor skill and
    # think it is building the framework. Assert the user-project context explicitly.
    case "$FLOW_PATH" in
      brownfield) SANDBOX_DESC="adopting GroundWork onto an existing codebase" ;;
      delivery)   SANDBOX_DESC="delivering a sealed, approved bet through the Delivery phase" ;;
      *)          SANDBOX_DESC="building a brand-new product with GroundWork" ;;
    esac
    cat > "$SANDBOX_DIR/CLAUDE.md" <<EOF
# Project context

This is a GroundWork **$FLOW_PATH user project** — a sandbox for $SANDBOX_DESC. It is NOT the GroundWork framework source repository.

- You are the GroundWork facilitator working in a user project here.
- Ignore any guidance loaded from a parent repository (e.g. a contributor or
  framework-development skill). It does not apply in this project.
- Follow the skills installed in \`.agents/\` and \`.groundwork/\` as a normal user
  project would. Start by running the \`groundwork-orchestrator\` skill.
EOF

    # Fresh git repo so the flow can commit its documents.
    if [ ! -d "$SANDBOX_DIR/.git" ]; then
      print_substep "Initializing git repo..."
      git -C "$SANDBOX_DIR" init -q
    fi
    if [ "$FLOW_PATH" = "brownfield" ]; then
      print_substep "Committing existing codebase as the adoption baseline..."
      git -C "$SANDBOX_DIR" add -A
      git -C "$SANDBOX_DIR" -c user.email=sim@groundwork.dev -c user.name=sim commit -q -m "baseline: existing codebase (pre-GroundWork)"
    fi

    print_step "Running 'groundwork init' in sandbox..."
    (cd "$SANDBOX_DIR" && node "$REPO_ROOT/bin/groundwork.js" init)

    # Delivery: seal the bet. One baseline commit carrying the approved pitch,
    # technical design, decomposition tree, and the taskcli stubs, tagged
    # `bet/task-capture/approved` — the sealed baseline the readiness gate and the
    # prose-integrity reconciliation hold delivery to. The gitignored `.groundwork/cache/`
    # (board, memlog, packs) is intentionally absent — delivery creates it at Step 0.
    if [ "$FLOW_PATH" = "delivery" ]; then
      print_substep "Sealing the 'task-capture' bet (baseline commit + approved tag)..."
      git -C "$SANDBOX_DIR" add -A
      git -C "$SANDBOX_DIR" -c user.email=sim@groundwork.dev -c user.name=sim \
        commit -q -m "bet(task-capture): approve decomposition"
      git -C "$SANDBOX_DIR" tag "bet/task-capture/approved"
    fi

    # --- Resume from a captured checkpoint (docs/ + .groundwork/ from a green run) ---
    if [ -n "$FROM" ]; then
      FROM_DIR="$REPO_ROOT/.sandboxes/checkpoints/$FROM"
      [ -d "$FROM_DIR" ] || fail "No checkpoint '$FROM' at $FROM_DIR (see: ./dev sandbox checkpoint list)"
      print_step "Seeding from checkpoint '$FROM' (resume mid-flow)..."
      if [ -d "$FROM_DIR/docs" ]; then
        mkdir -p "$SANDBOX_DIR/docs"
        cp -R "$FROM_DIR/docs/." "$SANDBOX_DIR/docs/"
      fi
      # Merge over the fresh init state — checkpoint never carries .agents/ (always fresh skills).
      [ -d "$FROM_DIR/.groundwork" ] && cp -R "$FROM_DIR/.groundwork/." "$SANDBOX_DIR/.groundwork/"
    fi

    # Marker read by the structural checklist and review to pick the right contract.
    printf '{"path": "%s", "suite": "%s"}\n' "$FLOW_PATH" "$SUITE" > "$SANDBOX_DIR/.groundwork-sim.json"

    # Verify the install produced the expected skill files.
    print_step "Verifying init..."
    MISSING=0
    for p in \
      ".agents/skills/groundwork-orchestrator/SKILL.md" \
      ".groundwork/skills/groundwork-product-brief/instructions.md" \
      ".groundwork/skills/groundwork-architecture/instructions.md" \
      ".groundwork/skills/groundwork-scaffold/instructions.md" \
      ".groundwork/skills/groundwork-mvp/instructions.md" \
      ".groundwork/skills/groundwork-bet/instructions.md" \
      ".groundwork/config/generators.json"; do
      if [ ! -e "$SANDBOX_DIR/$p" ]; then
        print_error "Missing: $p"
        MISSING=1
      fi
    done
    if [ "$MISSING" -ne 0 ]; then
      fail "Init incomplete — check bin/groundwork.js install logic."
    fi

    if [ "$SIMULATE" -eq 1 ]; then
      print_step "Seeding simulation harness ($FLOW_PATH, suite: $SUITE)..."
      node "$REPO_ROOT/scripts/seed_simulation.js" "$SUITE" "$SANDBOX_DIR" "$FLOW_PATH"
    fi

    # Baseline-commit the fully provisioned sandbox. Background sessions isolate
    # their edits in a git worktree checked out from HEAD, so everything a session
    # reads mid-flow (installed skills, .groundwork config, doc seeds, fixture
    # source) must be committed or the isolated checkout is missing it. Run
    # records (.simrun/) stay out of git — harness state, not flow output.
    grep -qxF '.simrun/' "$SANDBOX_DIR/.gitignore" 2>/dev/null || echo '.simrun/' >> "$SANDBOX_DIR/.gitignore"
    if [ -n "$(git -C "$SANDBOX_DIR" status --porcelain)" ]; then
      print_substep "Committing provisioned baseline..."
      git -C "$SANDBOX_DIR" add -A
      git -C "$SANDBOX_DIR" -c user.email=sim@groundwork.dev -c user.name=sim \
        commit -q -m "chore: sandbox baseline (provisioned)"
    fi

    print_success "Sandbox ready at $SANDBOX_DIR"
    if [ "$SIMULATE" -eq 1 ]; then
      print_info "Start a new chat from that folder and run /simulate-$FLOW_PATH to dry-run the flow against the simulated user."
      print_info "Or drive it autonomously: ./dev sim run $NAME --reuse"
      print_info "After it runs: ./dev sim assess $NAME   (transcript + checklist + judge + findings)"
    else
      print_info "Start a new chat from that folder and ask GroundWork to begin a new project."
    fi
    ;;
  lint)
    SUBCMD=$2
    if [ "$SUBCMD" = "skills" ] || [ -z "$SUBCMD" ]; then
      print_logo "Linting"
      print_step "Running skill conformance lint..."
      python3 scripts/lint_skills.py
    else
      print_info "Unknown lint target: $SUBCMD (try: ./dev lint skills)"
      exit 1
    fi
    ;;
  check)
    SUBCMD=$2
    if [ "$SUBCMD" = "sync-anchors" ]; then
      print_logo "Checking"
      print_step "Verifying engineer skill sync anchors..."
      python3 scripts/check_sync_anchors.py
    else
      print_logo
      echo -e "  Local Development CLI for GroundWork"
      echo ""
      echo -e "  ${BOLD}USAGE${NC}"
      echo -e "  ${DIM}$ ${MAGENTA}./dev${NC} ${CYAN}check${NC} [action]"

      print_category "ACTIONS"
      print_cmd "sync-anchors" "Verify engineer skill sync anchors match principle file hashes"
      echo ""
    fi
    ;;
  *)
    print_logo
    echo -e "  Local Development CLI for GroundWork"
    echo ""
    echo -e "  ${BOLD}USAGE${NC}"
    echo -e "  ${DIM}$ ${MAGENTA}./dev${NC} ${CYAN}<verb>${NC} [nouns...]"

    print_category "SETUP"
    print_cmd "sandbox" "Create a standalone GroundWork project sandbox (.sandboxes/<name>, default greenfield)"
    print_cmd "sandbox --simulate" "...and seed a simulated-user harness so a chat can dry-run the flow (run /simulate-<path>)"
    print_cmd "sandbox --brownfield" "Seed the synthetic existing-codebase fixture + baseline commit instead of an empty repo"
    print_cmd "sandbox --repo=owner/repo[@ref]" "Brownfield from a real GitHub repo (cloned once into a gitignored cache; --refresh to re-pull)"
    print_cmd "sandbox --from=<label>" "Resume mid-flow by seeding docs/ + .groundwork/ from a captured checkpoint"
    print_cmd "sandbox review" "Render the latest chat transcript + structural checklist into .sandboxes/<name>-review/"

    print_category "SIMULATION (the driver loop — see ./dev sim)"
