#!/usr/bin/env bash
set -e

# Change to the directory of this script to ensure relative paths work
cd "$(dirname "$0")"

# Load environment variables if present
if [ -f ".env" ]; then
  set -a
  source .env
  set +a
fi

# Source UI functions
if [ -f "scripts/_ui.sh" ]; then
  source scripts/_ui.sh
else
  # Fallback functions if ui script is missing
  print_logo() { echo "GroundWork Dev CLI"; }
  print_step() { echo "-> $1"; }
  print_info() { echo "  $1"; }
  print_error() { echo "ERROR: $1"; }
  fail() { echo "ERROR: $1"; exit 1; }
fi

COMMAND=$1

case "$COMMAND" in
  test|eval)
    SUBCMD=$2
    if [ "$SUBCMD" = "nx" ]; then
      print_logo "Testing"
      print_step "Running Nx tests..."
      npx nx run-many -t test
    elif [ "$SUBCMD" = "generation" ]; then
      print_logo "Testing"
      print_step "Building TypeScript generators..."
      npm install --silent && npm run build
      print_step "Running Generation Tests (structural, all combos)..."
      if [ ! -d "tests/scaffolds/venv" ]; then
          print_substep "Creating venv..."
          python3 -m venv tests/scaffolds/venv
          source tests/scaffolds/venv/bin/activate
          pip install pytest httpx pytest-asyncio allpairspy
      else
          source tests/scaffolds/venv/bin/activate
      fi
      pytest tests/scaffolds/test_generation.py -v -s
    elif [ "$SUBCMD" = "compilation" ]; then
      print_logo "Testing"
      print_step "Building TypeScript generators..."
      npm install --silent && npm run build
      print_step "Running Compilation Tests (pairwise, compile checks)..."
      if [ ! -d "tests/scaffolds/venv" ]; then
          print_substep "Creating venv..."
          python3 -m venv tests/scaffolds/venv
          source tests/scaffolds/venv/bin/activate
          pip install pytest httpx pytest-asyncio allpairspy
      else
          source tests/scaffolds/venv/bin/activate
      fi
      pytest tests/scaffolds/test_compilation.py -v -s
    elif [ "$SUBCMD" = "scaffolds" ]; then
      print_logo "Testing"
      print_step "Building TypeScript generators..."
      npm install --silent && npm run build
      print_step "Running Scaffold End-to-End Tests..."
      if [ ! -d "tests/scaffolds/venv" ]; then
          print_substep "Creating venv..."
          python3 -m venv tests/scaffolds/venv
          source tests/scaffolds/venv/bin/activate
          pip install pytest httpx pytest-asyncio allpairspy
      else
          source tests/scaffolds/venv/bin/activate
      fi
      pytest tests/scaffolds/test_scaffolds.py -v -s
    elif [ "$SUBCMD" = "run" ]; then
      SUITE=$3
      SCENARIO=$4

      if [ -z "$SUITE" ]; then
          print_logo "Evaluation Suites"
          print_info "Available suites:"
          echo ""

          # Dynamically list available suites using Python
          python3 tests/evals/list_suites.py

          echo ""
          print_info "Usage: ./dev eval run <suite_name> [scenario_name]"
          print_info "Example: ./dev eval run storytelling_engine 01_product_brief"
          exit 1
      fi

      print_logo "Running Evaluation"
      print_step "Suite: $SUITE"

      print_substep "Activating evaluation environment..."
      cd tests/evals
      if [ ! -d "venv" ]; then
          print_substep "Creating venv..."
          python3 -m venv venv
          source venv/bin/activate
          pip install -r requirements.txt
      else
          source venv/bin/activate
      fi

      # Handle extra CLI flags dynamically (e.g. starting with -)
      if [ -n "$SCENARIO" ] && [[ ! "$SCENARIO" =~ ^- ]]; then
          EXTRA_ARGS="${@:5}"
      else
          SCENARIO=""
          EXTRA_ARGS="${@:4}"
      fi

      if [ -n "$SCENARIO" ]; then
          python conversational_eval.py --suite "$SUITE" --scenario "$SCENARIO" $EXTRA_ARGS
      else
          python conversational_eval.py --suite "$SUITE" --all $EXTRA_ARGS
      fi
    elif [ "$SUBCMD" = "clean" ]; then
      print_logo "Cleaning"
      print_step "Cleaning evaluation sandboxes and caches..."
      rm -rf .sandboxes/evals tests/evals/cache/*
      print_success "Cleaned."
    elif [ "$SUBCMD" = "validate" ]; then
      SUITE=$3

      print_logo "Scaffold Validation"

      cd tests/evals
      if [ ! -d "venv" ]; then
          print_substep "Creating venv..."
          python3 -m venv venv
          source venv/bin/activate
          pip install -r requirements.txt
      else
          source venv/bin/activate
      fi

      EXTRA_ARGS="${@:4}"

      if [ -n "$SUITE" ]; then
          python validate_scaffold.py --suite "$SUITE" $EXTRA_ARGS
      else
          python validate_scaffold.py $EXTRA_ARGS
      fi
    else
      print_logo
      echo -e "  Local Development CLI for GroundWork"
      echo ""
      echo -e "  ${BOLD}USAGE${NC}"
      echo -e "  ${DIM}$ ${MAGENTA}./dev${NC} ${CYAN}eval${NC} [action]"

      print_category "ACTIONS"
      print_cmd "run" "Run conversational evaluations (lists suites if empty)"
      print_cmd "clean" "Clear eval caches & sandboxes"
      print_cmd "validate" "Manually probe a scaffold workspace (boots + health checks)"
      echo ""
    fi
    ;;
  sandbox)
    # Create a standalone GroundWork project sandbox seeded with the same
    # starting state a real user gets from `npx groundwork init`. Unlike the
    # eval sandbox (.sandboxes/evals), this one is NOT wiped by eval runs, so
    # you can start a fresh chat from the folder and walk the greenfield flow.
    NAME="greenfield"
    FORCE=0
    NOBUILD=0
    SIMULATE=0
    SUITE="storytelling_engine"
    for arg in "${@:2}"; do
      case "$arg" in
        --force) FORCE=1 ;;
        --no-build) NOBUILD=1 ;;
        --simulate) SIMULATE=1 ;;
        --simulate=*) SIMULATE=1; SUITE="${arg#*=}" ;;
        -*) print_error "Unknown flag: $arg"; exit 1 ;;
        *) NAME="$arg" ;;
      esac
    done

    REPO_ROOT="$PWD"
    SANDBOX_DIR="$REPO_ROOT/.sandboxes/$NAME"

    print_logo "Sandbox"
    print_step "Target: .sandboxes/$NAME"

    if [ -e "$SANDBOX_DIR" ] && [ -n "$(ls -A "$SANDBOX_DIR" 2>/dev/null)" ]; then
      if [ "$FORCE" -ne 1 ]; then
        printf "  %s already exists and is not empty. Overwrite? [y/N] " "$SANDBOX_DIR"
        read -r REPLY
        case "$REPLY" in
          [yY]|[yY][eE][sS]) ;;
          *) print_error "Aborted."; exit 1 ;;
        esac
      fi
      print_substep "Wiping existing sandbox..."
      rm -rf "$SANDBOX_DIR"
    fi
    mkdir -p "$SANDBOX_DIR"

    if [ "$NOBUILD" -ne 1 ]; then
      print_step "Building generators (dist/)..."
      npm install --silent && npm run build
    else
      print_substep "Skipping build (--no-build)."
    fi

    print_step "Running 'groundwork init' in sandbox..."
    (cd "$SANDBOX_DIR" && node "$REPO_ROOT/bin/groundwork.js" init)

    # Make it a realistic Nx-style project root so the scaffold skill is happy.
    printf '{"name": "%s"}\n' "$NAME" > "$SANDBOX_DIR/package.json"
    printf '{}\n' > "$SANDBOX_DIR/nx.json"

    # This sandbox is nested inside the GroundWork repo. Without a local boundary,
    # a chat opened here could inherit the repo's CLAUDE.md / contributor skill and
    # think it is building the framework. Assert the user-project context explicitly.
    cat > "$SANDBOX_DIR/CLAUDE.md" <<'EOF'
# Project context

This is a fresh **GroundWork user project** — a sandbox for building a brand-new
product with GroundWork. It is NOT the GroundWork framework source repository.

- You are the GroundWork facilitator helping build a new product here.
- Ignore any guidance loaded from a parent repository (e.g. a contributor or
  framework-development skill). It does not apply in this project.
- Follow the skills installed in `.agents/` and `.groundwork/` as a normal user
  project would. Start by running the `groundwork-orchestrator` skill.
EOF

    # Fresh git repo so the greenfield flow can commit its documents.
    if [ ! -d "$SANDBOX_DIR/.git" ]; then
      print_substep "Initializing git repo..."
      git -C "$SANDBOX_DIR" init -q
    fi

    # Verify the install produced the expected skill files.
    print_step "Verifying init..."
    MISSING=0
    for p in \
      ".agents/skills/groundwork-orchestrator/SKILL.md" \
      ".agents/groundwork/skills/groundwork-product-brief/instructions.md" \
      ".agents/groundwork/skills/groundwork-architecture/instructions.md" \
      ".agents/groundwork/skills/groundwork-scaffold/instructions.md" \
      ".agents/groundwork/skills/groundwork-mvp/instructions.md" \
      ".agents/groundwork/skills/groundwork-bet/instructions.md" \
      ".groundwork/config/generators.json"; do
      if [ ! -e "$SANDBOX_DIR/$p" ]; then
        print_error "Missing: $p"
        MISSING=1
      fi
    done
    if [ "$MISSING" -ne 0 ]; then
      fail "Init incomplete — check bin/groundwork.js install logic."
    fi

    if [ "$SIMULATE" -eq 1 ]; then
      print_step "Seeding simulation harness (suite: $SUITE)..."
      node "$REPO_ROOT/scripts/seed_simulation.js" "$SUITE" "$SANDBOX_DIR"
    fi

    print_success "Sandbox ready at $SANDBOX_DIR"
    if [ "$SIMULATE" -eq 1 ]; then
      print_info "Start a new chat from that folder and run /simulate-greenfield to dry-run the flow against the simulated user."
    else
      print_info "Start a new chat from that folder and ask GroundWork to begin a new project."
    fi
    ;;
  check)
    SUBCMD=$2
    if [ "$SUBCMD" = "sync-anchors" ]; then
      print_logo "Checking"
      print_step "Verifying engineer skill sync anchors..."
      python3 scripts/check_sync_anchors.py
    else
      print_logo
      echo -e "  Local Development CLI for GroundWork"
      echo ""
      echo -e "  ${BOLD}USAGE${NC}"
      echo -e "  ${DIM}$ ${MAGENTA}./dev${NC} ${CYAN}check${NC} [action]"

      print_category "ACTIONS"
      print_cmd "sync-anchors" "Verify engineer skill sync anchors match principle file hashes"
      echo ""
    fi
    ;;
  *)
    print_logo
    echo -e "  Local Development CLI for GroundWork"
    echo ""
    echo -e "  ${BOLD}USAGE${NC}"
    echo -e "  ${DIM}$ ${MAGENTA}./dev${NC} ${CYAN}<verb>${NC} [nouns...]"

    print_category "SETUP"
    print_cmd "sandbox" "Create a standalone GroundWork project sandbox (.sandboxes/<name>, default greenfield)"
    print_cmd "sandbox --simulate" "...and seed a simulated-user harness so a chat can dry-run the greenfield flow (run /simulate-greenfield)"

    print_category "QUALITY & TESTING"
    print_cmd "eval run" "Run conversational evaluations (lists suites if empty)"
    print_cmd "eval validate" "Manually probe a scaffold workspace (boots + health checks)"
    print_cmd "test generation" "Run generator structural tests (fast, all combinations)"
    print_cmd "test compilation" "Run generator compilation tests (pairwise, go build / tsc / uv sync)"
    print_cmd "test scaffolds" "Run end-to-end scaffold boot tests (Docker, health checks)"
    print_cmd "test nx" "Run Nx workspace tests"
    print_cmd "check sync-anchors" "Verify engineer skill sync anchors match principle file hashes"
    echo ""
    ;;
esac
