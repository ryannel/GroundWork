#!/usr/bin/env bash
set -e

# Change to the directory of this script to ensure relative paths work
cd "$(dirname "$0")"

COMMAND=$1

case "$COMMAND" in
  test|eval)
    SUBCMD=$2
    if [ "$SUBCMD" = "nx" ]; then
      echo "Running Nx tests..."
      npx nx run-many -t test
    elif [ "$SUBCMD" = "run" ]; then
      SUITE=$3
      SCENARIO=$4
      
      if [ -z "$SUITE" ]; then
          echo "Usage: ./dev eval run <suite_name> [scenario_name]"
          echo "Example: ./dev eval run storytelling_engine 01_product_brief"
          exit 1
      fi

      echo "Activating evaluation environment..."
      cd tests/evals
      if [ ! -d "venv" ]; then
          echo "Creating venv..."
          python3 -m venv venv
          source venv/bin/activate
          pip install -r requirements.txt
      else
          source venv/bin/activate
      fi
      
      if [ -n "$SCENARIO" ]; then
          python conversational_eval.py --suite "$SUITE" --scenario "$SCENARIO"
      else
          python conversational_eval.py --suite "$SUITE" --all
      fi
    elif [ "$SUBCMD" = "clean" ]; then
      echo "Cleaning evaluation sandboxes and caches..."
      rm -rf tests/evals/sandbox/* tests/evals/cache/*
      echo "Cleaned."
    else
      echo "Usage:"
      echo "  ./dev eval run <suite> [scenario]  # Run conversational evaluations"
      echo "  ./dev eval clean                   # Clear eval caches & sandboxes"
      echo "  ./dev test nx                      # Run Nx workspace tests"
    fi
    ;;
  *)
    echo "GroundWork Dev CLI"
    echo "Available commands:"
    echo "  test, eval    Commands for running tests and evaluations"
    ;;
esac
