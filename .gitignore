# ============================================================
# GroundWork — .gitignore
# Nx monorepo · Node / TypeScript
# ============================================================

# ----------------------------
# Dependencies
# ----------------------------
node_modules/

# ----------------------------
# Build output
# ----------------------------
dist/

# ----------------------------
# Nx cache & workspace data
# ----------------------------
.nx/

# ----------------------------
# OS & Editor
# ----------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# JetBrains IDEs
.idea/

# VS Code (keep workspace file, ignore local settings)
.vscode/
!.vscode/settings.json
!.vscode/extensions.json

# ----------------------------
# Environment & Secrets
# ----------------------------
.env
.env.*
!.env.example
!.env.*.example
!.env.template
!.env.*.template

# ----------------------------
# Test scaffolds & temp dirs
# ----------------------------
test-scaffold/
.sandboxes/
tmp_sandbox/
tmp_*/
pytest_out*.txt

# Generated service output (from Nx generators)
services/

# ----------------------------
# Logs & Transcripts
# ----------------------------
*.log
tests/evals/transcripts/**/*_[0-9]*_[0-9]*.json

# ----------------------------
# Python & Pytest
# ----------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.venv/
venv/

# ----------------------------
# Generated compose & dev-cli files
# ----------------------------
docker-compose.yml
tests/system/docker-compose.test.yml

# ----------------------------
# AI Agent Artifacts
# ----------------------------
plan.md
task.md
scratch.md
scratch.txt
walkthrough.md
implementation_plan.md
scratch/
