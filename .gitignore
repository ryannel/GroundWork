# ============================================================
# GroundWork — .gitignore
# Nx monorepo · Node / TypeScript
# ============================================================

# ----------------------------
# Dependencies
# ----------------------------
node_modules/

# ----------------------------
# Build output
# ----------------------------
dist/

# ----------------------------
# Nx cache & workspace data
# ----------------------------
.nx/

# ----------------------------
# OS & Editor
# ----------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# JetBrains IDEs
.idea/

# VS Code (keep workspace file, ignore local settings)
.vscode/
!.vscode/settings.json
!.vscode/extensions.json

# Agent local settings (machine-specific, not shared)
.agents/settings.local.json
.claude/settings.local.json

# Background-task git worktrees (created on demand, never committed)
.agents/worktrees/
.claude/worktrees/

# ----------------------------
# Environment & Secrets
# ----------------------------
.env
.env.*
!.env.example
!.env.*.example
!.env.template
!.env.*.template

# ----------------------------
# Test scaffolds & temp dirs
# ----------------------------
test-scaffold/
.sandboxes/
tmp_sandbox/
tmp_*/
pytest_out*.txt

# Generated service output (from Nx generators) — anchored to the repo root:
# an unanchored `services/` silently ignored generator template files like
# src/generators/flutter-app/files/lib/data/services/api_client.dart
/services/

# ----------------------------
# Logs & Transcripts
# ----------------------------
*.log
tests/evals/transcripts/**/*_[0-9]*_[0-9]*.json

# ----------------------------
# Python & Pytest
# ----------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.venv/
venv/

# ----------------------------
# Generated compose & dev-cli files
# ----------------------------
docker-compose.yml
tests/system/docker-compose.test.yml

# ----------------------------
# AI Agent Artifacts
# ----------------------------
plan.md
task.md
scratch.md
scratch.txt
walkthrough.md
implementation_plan.md
scratch/
tests/evals/runs/
.agents/scheduled_tasks.lock

# ----------------------------
# Brownfield eval fixture — real committed source, not generated output.
# The repo-wide `services/` and `docker-compose.yml` ignores would otherwise
# swallow the fixture's codebase on a fresh clone.
# ----------------------------
!tests/evals/fixtures/brownfield_monorepo/00_codebase/services/
!tests/evals/fixtures/brownfield_monorepo/00_codebase/services/**
!tests/evals/fixtures/brownfield_monorepo/00_codebase/docker-compose.yml
